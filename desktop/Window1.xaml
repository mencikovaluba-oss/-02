<Window x:Class="desktop.Window1"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:desktop"
        mc:Ignorable="d"
        Title="Window1" Height="450" Width="800">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="🔐 Модуль технолога" 
                   FontSize="24" 
                   FontWeight="Bold" 
                   HorizontalAlignment="Center" 
                   Margin="0,0,0,30"/>
        <TabControl Grid.Row="1" Margin="0,0,0,20">
            <TabItem Header="Вход">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Логин" Margin="0,5"/>
                    <TextBox x:Name="LoginUsername" Grid.Row="1" Margin="0,5"/>
                    <TextBlock Text="Пароль" Grid.Row="2" Margin="0,5"/>
                    <PasswordBox x:Name="LoginPassword" Grid.Row="3" Margin="0,5"/>
                    <Border Grid.Row="4" Margin="0,10" Padding="10" BorderBrush="#CCC" BorderThickness="1" CornerRadius="5">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Image x:Name="CaptchaImage" Grid.ColumnSpan="2" Height="80" Stretch="Uniform" Margin="0,5"/>
                            <Button x:Name="RefreshCaptchaBtn" Grid.Column="1" Content="⟳" Width="40" Margin="5,5,0,5"/>
                            <TextBlock Text="Введите код с картинки" Grid.Row="1" Margin="0,5"/>
                            <TextBox x:Name="CaptchaCode" Grid.Row="2" Margin="0,5"/>
                        </Grid>
                    </Border>
                    <Button x:Name="LoginBtn" Content="Войти" Grid.Row="5" Margin="0,20" Height="35"></Button>
                    
                    <TextBlock x:Name="LoginError" Grid.Row="6" Foreground="Red" TextWrapping="Wrap"/>
                </Grid>
            </TabItem>
            <TabItem Header="Регистрация">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="ФИО" Margin="0,5"/>
                    <TextBox x:Name="RegFullName" Grid.Row="1" Margin="0,5"/>
                    <TextBlock Text="Email" Grid.Row="2" Margin="0,5"/>
                    <TextBox x:Name="RegEmail" Grid.Row="3" Margin="0,5"/>
                    <TextBlock Text="Логин" Grid.Row="4" Margin="0,5"/>
                    <TextBox x:Name="RegUsername" Grid.Row="5" Margin="0,5"/>
                    <TextBlock Text="Пароль" Grid.Row="6" Margin="0,5"/>
                    <PasswordBox x:Name="RegPassword" Grid.Row="7" Margin="0,5"/>
                    <Border Grid.Row="8" Margin="0,10" Padding="10" BorderBrush="#CCC" BorderThickness="1" CornerRadius="5">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Image x:Name="RegCaptchaImage" Grid.ColumnSpan="2" Height="80" Stretch="Uniform" Margin="0,5"/>
                            <Button x:Name="RegRefreshCaptchaBtn" Grid.Column="1" Content="⟳" Width="40" Margin="5,5,0,5" Click="RegRefreshCaptcha_Click"/>
                            <TextBlock Text="Введите код с картинки" Grid.Row="1" Margin="0,5"/>
                            <TextBox x:Name="RegCaptchaCode" Grid.Row="2" Margin="0,5"/>
                        </Grid>
                    </Border>
                    <Button x:Name="RegisterBtn" Content="Зарегистрироваться" Grid.Row="9" Margin="0,20" Height="35" 
                            Background="#2196F3" Foreground="White" Click="Register_Click"/>
                    <TextBlock x:Name="RegError" Grid.Row="10" Foreground="Red" TextWrapping="Wrap"/>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
